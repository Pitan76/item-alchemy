{
  "multipart": [
    {
      "apply": { "model": "itemalchemy:block/emc_cable" }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm" }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm", "y": 180 }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm", "y": 90 }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm", "y": 270 }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm", "x": 270 }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "itemalchemy:block/emc_cable_arm", "x": 90 }
    }
  ]
}
